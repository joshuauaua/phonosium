#N canvas 0 0 560 400 10;
#X text 10 10 FX_PITCHSHIFT - ring modulation frequency shifter;
#X text 10 25 Multiplies signal by carrier oscillator (classic ring mod);
#X text 10 40 Low FREQ (1-20 Hz) = tremolo / AM effect;
#X text 10 55 Mid FREQ (50-200 Hz) = metallic pitch-shifting texture;
#X text 10 70 High FREQ (200-2000 Hz) = strong frequency shifting;
#X text 10 85 MIX (0-1): dry/wet blend;
#X text 10 100 -----------------------------------------------------;
#X obj 100 135 inlet~;
#X text 310 130 FREQ Hz (1-2000);
#X floatatom 310 145 6 1 2000 0 0 0;
#X text 430 130 MIX wet (0-1);
#X floatatom 430 145 5 0 1 0 0 0;
#X obj 310 175 osc~;
#X obj 100 175 *~;
#X obj 100 210 hip~ 20;
#X obj 100 245 expr 1 - $f1;
#X obj 200 245 *~;
#X obj 100 270 *~;
#X obj 150 305 +~;
#X obj 150 340 outlet~;
