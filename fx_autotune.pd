#N canvas 0 0 580 480 10;
#X text 10 10 FX_AUTOTUNE - chromatic pitch correction via ring mod;
#X text 10 25 fiddle~ detects pitch -> quantize to nearest semitone -> ring mod shift;
#X text 10 40 MIX: 0 = dry only\, 1 = ring-modded output only;
#X text 10 55 -----------------------------------------------------;
#X obj 100 100 inlet~;
#X obj 100 130 hip~ 10;
#X obj 100 165 *~ 2;
#X obj 100 200 fiddle~ 1024;
#X obj 100 240 expr if($f1 < 20\, 0\, 440 * pow(2\, int(log($f1/440) / log(2) * 12 + 0.5) / 12.0) - $f1);
#X obj 100 280 osc~ 0;
#X obj 100 320 *~;
#X floatatom 280 320 5 0 1 0 MIX - - 0;
#X obj 380 320 expr 1 - $f1;
#X obj 100 360 *~;
#X obj 280 360 *~;
#X obj 190 400 +~;
#X obj 190 440 outlet~;
#X obj 430 290 loadbang;
#X obj 430 315 f 0.8;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 0 8 0;
#X connect 8 0 9 0;
#X connect 4 0 10 0;
#X connect 9 0 10 1;
#X connect 10 0 14 0;
#X connect 11 0 14 1;
#X connect 4 0 13 0;
#X connect 11 0 12 0;
#X connect 12 0 13 1;
#X connect 14 0 15 0;
#X connect 13 0 15 1;
#X connect 15 0 16 0;
#X connect 17 0 18 0;
#X connect 18 0 11 0;
