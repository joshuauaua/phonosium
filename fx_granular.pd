#N canvas 0 0 720 600 10;
#X text 10 10 FX_GRANULAR - 3-voice granular synthesis with parabolic windows;
#X text 10 25 RATE (Hz): grain density - try 2 to 20 Hz;
#X text 10 40 SIZE (ms): how far back in buffer grains read - try 100-900;
#X text 10 55 MIX (0-1): dry/wet blend;
#X text 10 70 Grains are phase-staggered at 0 / 0.33 / 0.67 for smooth overlap;
#X text 10 85 -----------------------------------------------------;
#X obj 100 120 inlet~;
#X text 295 112 RATE Hz;
#X floatatom 295 127 5 1 30 0 0 0;
#X text 385 112 SIZE ms;
#X floatatom 385 127 5 50 900 0 0 0;
#X text 465 112 MIX wet;
#X floatatom 465 127 5 0 1 0 0 0;
#X obj 100 155 delwrite~ gbuf 1000;
